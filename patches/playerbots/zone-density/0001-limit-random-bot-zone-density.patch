+uint32 RandomPlayerbotMgr::CountRandomBotsInZone(uint32 zoneId)
+{
+    uint32 count = 0;
+    for (PlayerBotMap::const_iterator itr = GetPlayerBotsBegin(); itr != GetPlayerBotsEnd(); ++itr)
+    {
+        Player* bot = itr->second;
+        if (!bot || !bot->IsInWorld() || !IsRandomBot(bot))
+            continue;
+
+        if (bot->GetZoneId() == zoneId)
+            ++count;
+    }
+
+    return count;
+}
+
+bool RandomPlayerbotMgr::IsZoneOverDensityLimit(uint32 zoneId)
+{
+    if (!sPlayerbotAIConfig.zoneDensityEnabled)
+        return false;
+
+    if (std::find(sPlayerbotAIConfig.zoneDensityStarterZones.begin(),
+                  sPlayerbotAIConfig.zoneDensityStarterZones.end(), zoneId) !=
+        sPlayerbotAIConfig.zoneDensityStarterZones.end())
+        return CountRandomBotsInZone(zoneId) >= sPlayerbotAIConfig.zoneDensityStarterLimit;
+
+    if (std::find(sPlayerbotAIConfig.zoneDensityEarlyZones.begin(),
+                  sPlayerbotAIConfig.zoneDensityEarlyZones.end(), zoneId) !=
+        sPlayerbotAIConfig.zoneDensityEarlyZones.end())
+        return CountRandomBotsInZone(zoneId) >= sPlayerbotAIConfig.zoneDensityEarlyLimit;
+
+    return false;
+}
+
 void RandomPlayerbotMgr::RandomTeleport(Player* bot, std::vector<WorldLocation>& locs, bool hearth)
 {
     // ignore when alrdy teleported or not in the world yet.
@@ -1665,6 +1699,9 @@ void RandomPlayerbotMgr::RandomTeleport(Player* bot, std::vector<WorldLocation>&
         if (zone->team == 2 && bot->GetTeamId() == TEAM_HORDE)
