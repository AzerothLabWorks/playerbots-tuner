+# Optional random bot zone density caps. When enabled, random bot teleport
+# location selection skips capped zones that already have enough random bots.
+# This keeps small starter and early leveling zones from saturating while
+# allowing high global random bot counts.
+AiPlayerbot.ZoneDensity.Enabled = 0
+AiPlayerbot.ZoneDensity.StarterZoneLimit = 20
+AiPlayerbot.ZoneDensity.EarlyZoneLimit = 45
+AiPlayerbot.ZoneDensity.StarterZones = "1,12,14,85,141,215,3430,3524"
+AiPlayerbot.ZoneDensity.EarlyZones = "17,38,40,130,148,3433,3525"
+
 # Probability bots teleport to banker (city)
 # Default: 0.25
 AiPlayerbot.ProbTeleToBankers = 0.25
