+bool LfgDungeonTeleportTrigger::IsActive()
+{
+    if (!bot || !bot->IsInWorld() || bot->IsBeingTeleported() || bot->IsInCombat() || bot->isDead())
+        return false;
+
+    if (bot->InBattleground() || bot->InArena())
+        return false;
+
+    if (Map* map = bot->GetMap())
+        if (map->IsDungeon())
+            return false;
+
+    Group* group = bot->GetGroup();
+    if (!group || !group->isLFGGroup())
+        return false;
+
+    lfg::LfgState botState = sLFGMgr->GetState(bot->GetGUID());
+    lfg::LfgState groupState = sLFGMgr->GetState(group->GetGUID());
+    return botState >= lfg::LFG_STATE_DUNGEON || groupState >= lfg::LFG_STATE_DUNGEON;
+}
